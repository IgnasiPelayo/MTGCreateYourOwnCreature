<Window x:Class="MTGCreateYourOwnCreature.View.MTGCreatureEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View"
      xmlns:cardslist="clr-namespace:MTGCreateYourOwnCreature.View.Controls.CardsList"
      xmlns:inspector="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
      xmlns:modals="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Modals"
      xmlns:preview="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Preview"
      xmlns:vm="clr-namespace:MTGCreateYourOwnCreature.ViewModel"
      mc:Ignorable="d"
      Title="Magic the Gathering: Create your own Creature" Height="550" Width="980">

    <Window.DataContext>
        <vm:MTGCreatureEditorVM/>
    </Window.DataContext>
    
    <Grid>
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="0"/>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ParentPickerVisibility}" Value="Visible">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="12"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0">
                <MenuItem Header="File">
                    <MenuItem Header="Import"
                              Command="{Binding ImportCommand}"/>
                    <MenuItem Header="Export"/>
                </MenuItem>
            </Menu>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#DDD"
                        BorderThickness="0,0,1,0"
                        Padding="4">

                    <cardslist:CardListControl/>

                </Border>

                <Border Grid.Column="1"
                        BorderBrush="#DDD"
                        BorderThickness="0,0,1,0"
                        Padding="4">

                    <inspector:CardInspectorControl DataContext="{Binding CurrentCard}"/>
                    
                </Border>

                <Border Grid.Column="2"
                        BorderBrush="#DDD"
                        BorderThickness="0,0,1,0"
                        Padding="4">

                    <preview:CardPreviewControl DataContext="{Binding CurrentCard}"/>

                </Border>
            </Grid>
        </Grid>

        <modals:ParentCardPickerModalControl Visibility="{Binding ParentPickerVisibility}"/>

    </Grid>
</Window>
