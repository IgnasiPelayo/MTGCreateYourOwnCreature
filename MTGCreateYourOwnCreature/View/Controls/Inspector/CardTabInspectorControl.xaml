<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Inspector.CardTabInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource InspectorPropertyTitle}"
                   Text="Additional Information"/>

        <TabControl Grid.Row="1"
                    Margin="0,5,0,0"
                    Style="{StaticResource RoundedTabControl}">
            
            <TabItem Style="{DynamicResource RoundedTabItem}"
                     Tag="TopLeft"
                     Header="Stats"
                     Padding="10,1,10,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <local:CardManaCostInspectorControl/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <local:CardInheritedNumericInspectorControl Label="Power"
                                                                        LocalValue="{Binding Power}"
                                                                        InheritedValue="{Binding ResolvedInheritedPower}"
                                                                        TotalValue="{Binding ResolvedTotalPower}"
                                                                        HasInheritance="{Binding HasParentCard}"/>

                            <local:CardInheritedNumericInspectorControl Grid.Column="1"
                                                                        Label="Toughness"
                                                                        LocalValue="{Binding Toughness}"
                                                                        InheritedValue="{Binding ResolvedInheritedToughness}"
                                                                        TotalValue="{Binding ResolvedTotalToughness}"
                                                                        HasInheritance="{Binding HasParentCard}"/>
                        </Grid>
                    </Grid>

                </ScrollViewer>
            </TabItem>

            <TabItem Style="{DynamicResource RoundedTabItem}"
                     Header="Traits"
                     Padding="10,1,10,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <local:CardTraitsInspectorControl Label="Tags"
                                                          ItemsSource="{Binding Tags}"
                                                          NewValue="{Binding NewTag}"
                                                          AddCommand="{Binding AddTagCommand}"
                                                          RemoveCommand="{Binding RemoveTagCommand}"/>

                        <local:CardTraitsInspectorControl Grid.Row="1"
                                                          Label="Keywords"
                                                          ItemsSource="{Binding Keywords}"
                                                          NewValue="{Binding NewKeyword}"
                                                          AddCommand="{Binding AddKeywordCommand}"
                                                          RemoveCommand="{Binding RemoveKeywordCommand}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{DynamicResource RoundedTabItem}"
                     Tag="TopRight"
                     Header="Information"
                     Padding="10,1,10,0">
                <TextBlock Text="Information content"/>
            </TabItem>
        </TabControl>
    </Grid>

</UserControl>
