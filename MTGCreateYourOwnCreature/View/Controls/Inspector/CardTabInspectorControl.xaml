<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Inspector.CardTabInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource InspectorPropertyTitle}"
                   Text="Additional Information"/>

        <TabControl Grid.Row="1"
                    Margin="0,5,0,0"
                    Style="{StaticResource RoundedTabControl}">
            <TabItem Style="{DynamicResource RoundedTabItem}"
                 Tag="TopLeft"
                 Header="Stats">

                <local:CardManaCostInspectorControl/>
            </TabItem>

            <TabItem Style="{DynamicResource RoundedTabItem}"
                 Header="Traits">
                <TextBlock Text="Traits content"/>
            </TabItem>

            <TabItem Style="{DynamicResource RoundedTabItem}"
                 Tag="TopRight"
                 Header="Information">
                <TextBlock Text="Information content"/>
            </TabItem>
        </TabControl>
    </Grid>

</UserControl>
