<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Inspector.CardNameInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource InspectorPropertyTitle}"
                   Text="Card Name"/>

        <Border Grid.Row="1"
                Style="{StaticResource RoundedBorder}"
                Margin="0,5,0,0"
                Padding="2">

            <Grid>
                <TextBox Text="{Binding Card.Name, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Background="Transparent"
                         BorderThickness="0"
                         Cursor="IBeam"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         Padding="2,0,22,0"
                         VerticalAlignment="Top"/>

                <TextBlock Style="{StaticResource EditableTextIcon}"
                           Margin="0,5,4,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
