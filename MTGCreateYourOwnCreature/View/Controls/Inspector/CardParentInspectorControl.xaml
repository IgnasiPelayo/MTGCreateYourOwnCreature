<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Inspector.CardParentInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <StackPanel Orientation="Horizontal">

        <TextBlock Text="Parent Card"
                   FontWeight="SemiBold"
                   Foreground="#999"
                   FontSize="11"/>

        <Button Margin="10,0,0,0"
                Width="Auto">

            <TextBlock Text="{Binding ParentCreatureCard.Name, TargetNullValue=None}"
                       HorizontalAlignment="Center"/>

        </Button>
        
        
    </StackPanel>

</UserControl>
