<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Inspector.CardInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">


    <Grid Margin="12,12,6,12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <local:CardNameInspectorControl/>

        <local:CardParentInspectorControl Grid.Row="1"
                                          Padding="0,15,0,0"/>

        <local:CardCategoryInspectorControl Grid.Row="2"
                                            Padding="0,15,0,0"/>

        <Separator Grid.Row="3"
                   Margin="0,15,0,0"/>

        <local:CardTabInspectorControl Grid.Row="4"
                                       Padding="0,15,0,0"/>

        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="9"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Separator Margin="0,4"/>

            <Button Grid.Row="1"
                    Style="{StaticResource RedRoundedButton}"
                    Content="🗑️ Delete Creature"
                    Command="{Binding RemoveCreatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Grid>
    </Grid>
</UserControl>
