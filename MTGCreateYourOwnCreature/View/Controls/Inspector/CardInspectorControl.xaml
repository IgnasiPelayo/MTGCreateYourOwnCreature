             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Inspector"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Margin="12">

        <StackPanel Orientation="Vertical">

            <local:CardNameInspectorControl/>
            
            <local:CardParentInspectorControl Padding="0,10,0,0"/>

        </StackPanel>
        
    
    </Grid>
</UserControl>
