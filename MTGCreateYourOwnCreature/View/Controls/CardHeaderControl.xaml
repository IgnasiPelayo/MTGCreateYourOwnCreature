<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.CardHeaderControl"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">


    <Border Background="#FFF8F8F8"
            BorderBrush="#FFD8D8D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8"
            MinHeight="52">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#FFF8F8F8"/>

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFF1F1F1"/>
                    </Trigger>
                </Style.Triggers>

            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsNameReadOnly, ElementName=root}"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Background="Transparent"
                     VerticalAlignment="Top"
                     AcceptsReturn="True"/>

            <local:ManaCostControl Grid.Column="1"
                                   Mana="{Binding Mana.Manas}"
                                   VerticalAlignment="Top"
                                   MaxHeight="15"/>
        </Grid>
    </Border>
</UserControl>
