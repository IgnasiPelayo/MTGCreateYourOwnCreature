<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Modals.DeleteConfirmationModalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Modals"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Border Background="#80000000">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding CloseDeleteModalCommand}"/>
            </Border.InputBindings>

        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource NoHoverRoundedBorder}">

                <Grid Margin="10.30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Confirm Deletion"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10,0,0,0"/>

                    <Viewbox Grid.Row="1"
                             Margin="10,20">

                        <TextBlock Text="{Binding DeleteWarningText}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Viewbox>
                    
                    <Grid Grid.Row="2"
                          HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Style="{StaticResource RoundedButton}"
                                Content="Cancel" 
                                Margin="10,0"
                                Padding="20,0"
                                Command="{Binding CloseDeleteModalCommand}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource RedRoundedButton}"
                                Content="Confirm"
                                Margin="10,0" 
                                Padding="20,0"
                                Command="{Binding ConfirmDeleteCreatureCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
