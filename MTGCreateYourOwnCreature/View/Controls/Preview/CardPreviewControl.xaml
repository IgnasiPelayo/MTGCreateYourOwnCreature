<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Preview.CardPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Preview"
             xmlns:mana="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Mana"
             xmlns:converters="clr-namespace:MTGCreateYourOwnCreature.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:ManaToSymbolsConverter x:Key="ManaConverter"/>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">

        <Border Margin="50"
                BorderBrush="Black"
                Background="Black"
                BorderThickness="30"
                CornerRadius="10"
                RenderOptions.EdgeMode="Aliased"
                Width="635"
                Height="889">

            <Grid>
                <Border Background="Red"
                        Height="750"
                        VerticalAlignment="Top"
                        CornerRadius="10,10,30,30"/>

                <Grid Margin="10,15,10,45">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="250"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <local:CardPreviewFrameControl Fill="{StaticResource PreviewFrameBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="10,0,0,5">

                                <TextBlock Text="{Binding Card.Name}"
                                           FontWeight="SemiBold"
                                           FontSize="35"/>
                            </Viewbox>

                            <Border Grid.Column="1"
                                    Padding="5,0,5,5"
                                    VerticalAlignment="Center">

                                <mana:ManaCostControl ItemsSource="{Binding ResolvedTotalMana, Converter={StaticResource ManaConverter}}"/>

                            </Border>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="5,5"
                            Background="Orange"/>
                    
                    <local:CardPreviewFrameControl Grid.Row="2"
                                                   Fill="{StaticResource PreviewFrameBrush}"/>
                    
                    <Border Grid.Row="3"
                            Margin="5,5,5,0"
                            Background="{StaticResource PreviewInformationBrush}"/>
                </Grid>

                <local:CardPreviewFrameControl Height="50"
                                               Width="110"
                                               Margin="445,730,0,0"
                                               Fill="{StaticResource PreviewFrameBrush}"/>

            </Grid>
        </Border>
    </Viewbox>
    
</UserControl>
