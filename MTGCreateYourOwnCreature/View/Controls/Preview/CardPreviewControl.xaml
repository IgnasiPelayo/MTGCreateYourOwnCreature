<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Preview.CardPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Preview"
             xmlns:mana="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Mana"
             xmlns:converters="clr-namespace:MTGCreateYourOwnCreature.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:ManaToSymbolsConverter x:Key="ManaConverter"/>
        <converters:EnumDisplayConverter x:Key="EnumDisplayConverter"/>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">

        <Border Margin="50"
                BorderBrush="Black"
                Background="Black"
                BorderThickness="30"
                CornerRadius="10"
                Width="635"
                Height="889">

            <Grid>
                <Border Background="Red"
                        Height="750"
                        VerticalAlignment="Top"
                        CornerRadius="10,10,30,30"/>

                <Grid Margin="10,15,10,45">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="250"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <local:CardPreviewFrameControl Fill="{StaticResource PreviewFrameBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="10,0,0,5">

                                <TextBlock Text="{Binding Card.Name}"
                                           FontWeight="SemiBold"
                                           FontSize="35"/>
                            </Viewbox>

                            <Border Grid.Column="1"
                                    Padding="5,0,5,5"
                                    VerticalAlignment="Center">

                                <mana:ManaCostControl ItemsSource="{Binding ResolvedTotalMana, Converter={StaticResource ManaConverter}}"/>

                            </Border>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="5,5"
                            Background="Orange"/>


                    <Grid Grid.Row="2">

                        <local:CardPreviewFrameControl Fill="{StaticResource PreviewFrameBrush}"/>

                        <Viewbox Stretch="Uniform"
                                    StretchDirection="DownOnly"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="15,0">

                            <TextBlock FontSize="28"
                                       FontWeight="SemiBold">
                                
                                <Run Text="{Binding ResolvedCategory, Converter={StaticResource EnumDisplayConverter}}"/>
                                
                                <Run Text="{Binding ResolvedTags, Mode=OneWay}"/>
                            </TextBlock>
                        </Viewbox>
                    </Grid>

                    <Border Grid.Row="3"
                            x:Name="InformationBorder"
                            Margin="5,5,5,0"
                            Background="{StaticResource PreviewInformationBrush}">

                        <Grid x:Name="InformationContainer"
                              SizeChanged="OnInformationSizeChanged"
                              Margin="10,10,10,35"
                              VerticalAlignment="Center">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="DescriptionTextBlock"
                                       FontSize="30"
                                       Padding="10,0"
                                       TextWrapping="Wrap">
                                
                                <Run Text="{Binding ResolvedKeywords, Mode=OneWay}"/><Run Text="{Binding Description.ResolvedValue}"/>

                            </TextBlock>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FlavorText.HasValue}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Border Height="1"
                                        Margin="0,15,0,15"
                                        HorizontalAlignment="Stretch"
                                        Visibility="{Binding PreviewSeparatorVisibility}">

                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="Transparent"/>
                                            <GradientStop Offset="0.15" Color="Black"/>
                                            <GradientStop Offset="0.85" Color="Black"/>
                                            <GradientStop Offset="1" Color="Transparent"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           x:Name="FlavorTextBlock"
                                           Text="{Binding FlavorText.ResolvedValue}"
                                           FontStyle="Italic"
                                           Padding="10,0"
                                           FontSize="38"
                                           FontFamily="Gabriola"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>


                <Grid Height="50"
                      Width="110"
                      Margin="445,730,0,0">

                    <local:CardPreviewFrameControl Fill="{StaticResource PreviewFrameBrush}"/>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="35"
                               FontWeight="SemiBold"
                               Text="{Binding ResolvedTotalPowerToughness}"/>

                </Grid>
            </Grid>
        </Border>
    </Viewbox>
    
</UserControl>
