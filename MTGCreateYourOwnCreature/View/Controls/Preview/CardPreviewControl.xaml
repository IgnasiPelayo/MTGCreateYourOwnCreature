<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Preview.CardPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Preview"
             xmlns:mana="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Mana"
             xmlns:converters="clr-namespace:MTGCreateYourOwnCreature.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:ManaToSymbolsConverter x:Key="ManaConverter"/>
        <converters:EnumDisplayConverter x:Key="EnumDisplayConverter"/>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">

        <Border Margin="50"
                BorderBrush="Black"
                Background="Black"
                BorderThickness="30"
                CornerRadius="10"
                Width="635"
                Height="889">

            <Grid>
                <Border Background="{Binding PreviewBackgroundBrush}"
                        Height="750"
                        VerticalAlignment="Top"
                        CornerRadius="10,10,30,30"/>

                <Viewbox Stretch="Fill"
                         StretchDirection="DownOnly"
                         Margin="-1,-10,-18,0"
                         VerticalAlignment="Top">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLegendaryCreature}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>

                    <Grid>
                        <Border Background="Black" Margin="0,0,0,100"/>

                        <Path Data="M 6 4 C -1 12 -9 17 -11 35 C -12 47 -5 48 -5 52 C -6 55 -10.3333 55.3333 -13 57 C -13 67 -11 81 -2 88 C -2 96 -2 104 -2 112 C 3 120 9 126 12 138 C 12 147.3333 12 156.6667 12 166 H 564 C 563.6667 152.6667 563.3333 139.3333 563 126 C 566 120 570.3333 119.3333 573 116 C 573.3333 106.6667 572 95 574 88 C 587 82 585 69 588 58 C 584.3333 56.6667 580 54 579 50 C 586 45 587 40 586 35 C 585 20 576 13 568 4 C 550 17 542 18 504 19 C 501 11 495 7 489 2 C 425 29 406 15 348 2 L 345 9 C 327 7 302 -19 231 10 L 226 2 C 160 25 128 20 87 2 C 80 4 73 11 70 18 C 47 18 22 17 6 4"
                         Fill="{Binding PreviewBorderBrush}"/>
                    </Grid>
                </Viewbox>
                
                <Grid Margin="12,17,12,2">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="250"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <local:CardPreviewFrameControl Fill="{Binding PreviewBorderBrush}" Margin="-5"/>
                        <local:CardPreviewFrameControl Fill="{Binding PreviewFrameBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Viewbox Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     Margin="10,0,0,5">

                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="35"/>
                            </Viewbox>

                            <Border Grid.Column="1"
                                    Padding="5,0,5,5"
                                    VerticalAlignment="Center">

                                <mana:ManaCostControl ItemsSource="{Binding ResolvedTotalMana, Converter={StaticResource ManaConverter}}"/>

                            </Border>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1" Background="{Binding PreviewBorderBrush}"/>

                    <Border Grid.Row="1"
                            Margin="5,5"
                            Background="{StaticResource PlaceholderBrush}"/>


                    <Grid Grid.Row="2">

                        <local:CardPreviewFrameControl Fill="{Binding PreviewBorderBrush}" Margin="-5"/>
                        <local:CardPreviewFrameControl Fill="{Binding PreviewFrameBrush}"/>

                        <Viewbox Stretch="Uniform"
                                    StretchDirection="DownOnly"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="15,0">

                            <TextBlock FontSize="28"
                                       FontWeight="SemiBold">
                                
                                <Run Text="{Binding ResolvedCategory, Converter={StaticResource EnumDisplayConverter}}"/>
                                
                                <Run Text="{Binding ResolvedTags, Mode=OneWay}"/>
                            </TextBlock>
                        </Viewbox>
                    </Grid>

                    <Border Grid.Row="3" Background="{Binding PreviewBorderBrush}" Margin="0,0,0,-5"/>

                    <Border Grid.Row="3"
                            x:Name="InformationBorder"
                            Margin="5,5,5,0"
                            Background="{Binding PreviewInformationFrameBrush}">

                        <Grid x:Name="InformationContainer"
                              SizeChanged="OnInformationSizeChanged"
                              Margin="10,10,10,35"
                              VerticalAlignment="Center">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="DescriptionTextBlock"
                                       FontSize="30"
                                       Padding="10,0"
                                       TextWrapping="Wrap">
                                
                                <Run Text="{Binding ResolvedKeywords, Mode=OneWay}"/><Run Text="{Binding Description.ResolvedValue}"/>

                            </TextBlock>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FlavorText.HasValue}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Border Height="1"
                                        Margin="0,15,0,15"
                                        HorizontalAlignment="Stretch"
                                        Visibility="{Binding PreviewSeparatorVisibility}">

                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="Transparent"/>
                                            <GradientStop Offset="0.15" Color="Black"/>
                                            <GradientStop Offset="0.85" Color="Black"/>
                                            <GradientStop Offset="1" Color="Transparent"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           x:Name="FlavorTextBlock"
                                           Text="{Binding FlavorText.ResolvedValue}"
                                           FontStyle="Italic"
                                           Padding="10,0"
                                           FontSize="38"
                                           FontFamily="Gabriola"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4"
                          Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding PreviewCollectorNumber}"
                                       HorizontalAlignment="Left"
                                       Foreground="White"
                                       FontFamily="Cascadia Code Light"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock HorizontalAlignment="Left"
                                           Foreground="White">
                                    
                                    <Run Text="MTG · EN "
                                         FontFamily="Cascadia Code Light"/>
                                    <InlineUIContainer>
                                        <TextBlock Text="⚱ "
                                                   Foreground="White"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="-90"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </InlineUIContainer>
                                    <Run Text="  NACHET" FontFamily="Sylfaen"/>
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           Foreground="White"
                                           FontWeight="Light"
                                           Text="™ &amp; © 2026 MTG Creature Editor" FontFamily="Mongolian Baiti"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>


                <Grid Height="50"
                      Width="110"
                      Margin="445,730,0,0">

                    <local:CardPreviewFrameControl Fill="{Binding PreviewFrameBrush}"/>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="35"
                               FontWeight="SemiBold"
                               Text="{Binding ResolvedTotalPowerToughness}"/>

                </Grid>
            </Grid>
        </Border>
    </Viewbox>
    
</UserControl>
