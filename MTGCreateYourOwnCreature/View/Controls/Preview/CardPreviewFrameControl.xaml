<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Preview.CardPreviewFrameControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Preview"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="800">
    
    <Grid>
        <Ellipse Width="50"
                 Height="75"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 Fill="{Binding Fill, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <Ellipse Width="50"
                 Height="75"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Fill="{Binding Fill, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <Border Margin="25,0"
                BorderThickness="0"
                Background="{Binding Fill, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

    </Grid>
</UserControl>
