<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.CardsList.CardListItemControl"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.CardsList"
             xmlns:mana="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Mana"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Style="{StaticResource ListBoxItemRoundedBorder}"
            Padding="8"
            MinHeight="52">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Card.Name}"
                           TextWrapping="Wrap"
                           Background="Transparent"
                           VerticalAlignment="Top"
                           MaxWidth="125"/>

                <Border Grid.Column="1"
                        Height="15"
                        Padding="5,0,0,0"
                        VerticalAlignment="Top">

                    <mana:ManaTotalCostControl/>

                </Border>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding Card.ParentCreatureCard.Name}"
                       TextWrapping="Wrap"
                       FontSize="10"
                       FontWeight="Light"
                       FontStyle="Italic"/>
        </Grid>
    </Border>
</UserControl>
