<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.Mana.ManaTotalCostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls.Mana"
             xmlns:converters="clr-namespace:MTGCreateYourOwnCreature.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:ManaToSymbolsConverter x:Key="ManaConverter"/>
    </UserControl.Resources>

    <local:ManaCostControl ItemsSource="{Binding TotalMana, Converter={StaticResource ManaConverter}}"/>

</UserControl>
