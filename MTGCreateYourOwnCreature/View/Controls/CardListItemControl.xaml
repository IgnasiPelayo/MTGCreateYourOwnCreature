<UserControl x:Class="MTGCreateYourOwnCreature.View.Controls.CardListItemControl"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="CardItemBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8F8F8"/>
            <Setter Property="BorderBrush" Value="#FFD8D8D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, ElementName=root}" Value="True">
                    <Setter Property="Background" Value="#FFF1F1F1"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Background" Value="#FFF1F1F1"/>
                    <Setter Property="BorderBrush" Value="#FF8A8A8A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    

    <Border Style="{StaticResource CardItemBorderStyle}"
            Padding="8"
            MinHeight="52">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           TextWrapping="Wrap"
                           Background="Transparent"
                           VerticalAlignment="Top"
                           MaxWidth="125"/>

                <Border Grid.Column="1"
                        Height="15"
                        Padding="5,0,0,0"
                        VerticalAlignment="Top">

                    <local:ManaCostControl Grid.Column="1"
                           Mana="{Binding TotalMana}"/>

                </Border>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding ParentCreatureCard.Name}"
                       TextWrapping="Wrap"
                       FontSize="10"
                       FontWeight="Light"
                       FontStyle="Italic"/>
        </Grid>
    </Border>
</UserControl>
