<Window x:Class="MTGCreateYourOwnCreature.View.MTGCreateYourOwnCreature"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MTGCreateYourOwnCreature.View"
      xmlns:vm="clr-namespace:MTGCreateYourOwnCreature.ViewModel"
      mc:Ignorable="d"
      Title="Magic the Gathering: Create your own Creature" Height="450" Width="800">

    <Window.Resources>
        <vm:MTGCreateYourOwnCreatureVM x:Key="vm"/>
    </Window.Resources>
    
    <DockPanel DataContext="{StaticResource vm}">
        <Menu DockPanel.Dock="Top" Height="18" VerticalAlignment="Top">
            <MenuItem Header="File">
                <MenuItem Header="Import"
                          Command="{Binding ImportCommand}"/>
                <MenuItem Header="Export"
                          Command=""/>
            </MenuItem>
        </Menu>
        
        
    </DockPanel>
</Window>
