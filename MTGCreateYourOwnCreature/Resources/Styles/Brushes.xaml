    <SolidColorBrush x:Key="WhitePreviewInformationFrameBrush" Color="#FFFDFDFB"/>

    <ImageBrush x:Key="BlueBackgroundBrush" ImageSource="/Resources/Preview/blue_background.jpg"/>
    <SolidColorBrush x:Key="BluePreviewBorderBrush" Color="#FF194D98"/>
    <SolidColorBrush x:Key="BluePreviewFrameBrush" Color="#FFC4CFEB"/>
    <SolidColorBrush x:Key="BluePreviewInformationFrameBrush" Color="#FFECEDFF"/>

    <ImageBrush x:Key="BlackPreviewBackgroundBrush" ImageSource="/Resources/Preview/black_background.jpg"/>
    <SolidColorBrush x:Key="BlackPreviewBorderBrush" Color="#FF363636"/>
