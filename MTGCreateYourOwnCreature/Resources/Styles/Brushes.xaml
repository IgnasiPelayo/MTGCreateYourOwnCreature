    <SolidColorBrush x:Key="RedPreviewInformationFrameBrush" Color="#FFEBE0E6"/>
    
    <ImageBrush x:Key="GreenBackgroundBrush" ImageSource="/Resources/Preview/green_background.jpg"/>
