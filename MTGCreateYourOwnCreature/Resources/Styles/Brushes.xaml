    <SolidColorBrush x:Key="BlackPreviewInformationFrameBrush" Color="#FFE4E5E2"/>
    
    <ImageBrush x:Key="RedBackgroundBrush" ImageSource="/Resources/Preview/red_background.jpg"/>
    <SolidColorBrush x:Key="RedPreviewBorderBrush" Color="#FFC84332"/>
