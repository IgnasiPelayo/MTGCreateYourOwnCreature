<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BorderBrush" Color="#FFD8D8D8"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFF8F8F8"/>
    <SolidColorBrush x:Key="ControlBackgroundHoverBrush" Color="#FFF1F1F1"/>
    <SolidColorBrush x:Key="ControlBackgroundSelectedBrush" Color="#FFE8E8E8"/>
    
    <SolidColorBrush x:Key="ControlInheritedBorderBrush" Color="RoyalBlue"/>
    
    <ImageBrush x:Key="WhiteManaBrush" ImageSource="/Resources/ManaTextures/white.png"/>
    <ImageBrush x:Key="BlueManaBrush" ImageSource="/Resources/ManaTextures/blue.png"/>
    <ImageBrush x:Key="BlackManaBrush" ImageSource="/Resources/ManaTextures/black.png"/>
    <ImageBrush x:Key="RedManaBrush" ImageSource="/Resources/ManaTextures/red.png"/>
    <ImageBrush x:Key="GreenManaBrush" ImageSource="/Resources/ManaTextures/green.png"/>

    <ImageBrush x:Key="GenericBackgroundBrush" ImageSource="/Resources/Preview/generic_background.jpg"/>
    <SolidColorBrush x:Key="GenericPreviewBorderBrush" Color="#FFDDDDDB"/>
    <SolidColorBrush x:Key="GenericPreviewFrameBrush" Color="#FFC9C4C0"/>
    <SolidColorBrush x:Key="GenericPreviewInformationFrameBrush" Color="#FFBFC0C4"/>
    
    <ImageBrush x:Key="WhiteBackgroundBrush" ImageSource="/Resources/Preview/white_background.jpg"/>
    <SolidColorBrush x:Key="WhitePreviewBorderBrush" Color="#FFFDFDFB"/>
