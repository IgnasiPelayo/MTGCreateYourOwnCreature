    <ImageBrush x:Key="MultiColorPreviewBackgroundBrush" ImageSource="/Resources/Preview/multicolor_background.jpg"/>
    <SolidColorBrush x:Key="MultiColorPreviewBorderBrush" Color="#FFE9CC66"/>
    <SolidColorBrush x:Key="MultiColorPreviewFrameBrush" Color="#FFD6C180"/>
    <SolidColorBrush x:Key="MultiColorPreviewInformationFrameBrush" Color="#FFEEE7CD"/>
    
    <ImageBrush x:Key="PlaceholderBrush" ImageSource="/Resources/Preview/placeholder.jpg"/>

    <ImageBrush x:Key="TapBrush" ImageSource="/Resources/Preview/tap.png"/>
    
</ResourceDictionary>